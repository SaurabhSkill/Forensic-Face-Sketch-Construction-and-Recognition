# ============================================================
# Facenet Service — .dockerignore
# ============================================================

# Python cache
__pycache__/
**/__pycache__/
*.py[cod]
*.pyc

# Virtual environments
venv/
.venv/
env/

# Environment secrets — injected at runtime, never in image
.env
.env.*
!.env.example

# Git
.git/
.gitignore

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Docs
README.md
*.md

# Test files
tests/
pytest.ini
.coverage
