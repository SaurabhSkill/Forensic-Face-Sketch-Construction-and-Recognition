# ============================================================
# FaceFind Forensics - Frontend Environment Variables
# ============================================================
# Copy this file to .env and set the correct backend URL.
# ============================================================

# Local development
# REACT_APP_API_URL=http://localhost:5001

# AWS EC2 production — replace with your EC2 public IP
REACT_APP_API_URL=http://<your-ec2-public-ip>:5001

# ============================================================
# NOTE: variable name is REACT_APP_API_URL (not REACT_APP_API_BASE_URL)
# React only exposes variables prefixed with REACT_APP_
# After editing .env you must restart the dev server (npm start)
# ============================================================
