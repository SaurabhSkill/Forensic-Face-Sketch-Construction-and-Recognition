# ============================================================
# React Frontend — .dockerignore
# ============================================================

# Node dependencies (reinstalled by npm ci inside container)
node_modules/

# Build output (generated by npm run build inside container)
build/



# Environment secrets — NEVER copy into image; injected at runtime by Jenkins
.env
.env.*
!.env.example

# Git
.git/
.gitignore

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Docs
README.md
