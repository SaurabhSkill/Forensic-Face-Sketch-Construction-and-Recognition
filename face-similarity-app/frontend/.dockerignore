# ============================================================
# React Frontend — .dockerignore
# ============================================================

# Node dependencies (reinstalled by npm ci inside container)
node_modules/

# Build output (generated by npm run build inside container)
build/

# Environment secrets (injected at runtime)
.env
.env.local
.env.development
.env.production

# Git
.git/
.gitignore

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Docs
README.md
